#!/bin/bash
DB_USER="<DB_USER>"
DB_PASSWORD="<DB_PASSWORD>"

docker exec wordpress-mysql-1 mysqldump -u $DB_USER --password=$DB_PASSWORD --databases wp-mu --routines --triggers --set-gtid-purged=OFF --no-tablespaces | gzip > docker-entrypoint-initdb.d/backups/latest-mysqldump-daily.sql.gz; cp -p docker-entrypoint-initdb.d/backups/latest-mysqldump-daily.sql.gz docker-entrypoint-initdb.d/backups/`(date +%A)`-mysqldump-daily.sql.gz
